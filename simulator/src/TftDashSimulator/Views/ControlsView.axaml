<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="360" d:DesignHeight="700"
             x:Class="TftDashSimulator.Views.ControlsView">

    <Border Classes="ControlsPanel">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="10">

                <TextBlock Text="Dashboard Controls"
                          FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

                <ToggleButton x:Name="PauseToggle" Content="Pause Comms"
                             HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                             IsCheckedChanged="OnPauseToggled"/>

                <!-- Speed -->
                <StackPanel>
                    <TextBlock Text="Speed (MPH/KMH)"/>
                    <NumericUpDown x:Name="SpeedControl" Minimum="0" Maximum="200"
                                  Increment="5" FormatString="0"
                                  ValueChanged="OnNumericChanged"/>
                </StackPanel>

                <!-- RPM -->
                <StackPanel>
                    <TextBlock Text="RPM"/>
                    <NumericUpDown x:Name="RpmControl" Minimum="0" Maximum="15000"
                                  Increment="100" FormatString="0"
                                  ValueChanged="OnNumericChanged"/>
                </StackPanel>

                <!-- Coolant -->
                <StackPanel>
                    <TextBlock Text="Coolant Temperature"/>
                    <NumericUpDown x:Name="CoolantControl" Minimum="-20" Maximum="150"
                                  Increment="5" FormatString="0"
                                  ValueChanged="OnNumericChanged"/>
                </StackPanel>

                <!-- Battery -->
                <StackPanel>
                    <TextBlock Text="Battery Voltage (V)"/>
                    <NumericUpDown x:Name="BatteryControl" Minimum="0" Maximum="20"
                                  Increment="0.1" FormatString="0.0"
                                  ValueChanged="OnNumericChanged"/>
                </StackPanel>

                <!-- Fuel -->
                <StackPanel>
                    <TextBlock Text="Fuel Level"/>
                    <NumericUpDown x:Name="FuelControl" Minimum="0" Maximum="1024"
                                  Increment="10" FormatString="0"
                                  ValueChanged="OnNumericChanged"/>
                </StackPanel>

                <!-- Ambient -->
                <StackPanel>
                    <TextBlock Text="Ambient Temperature"/>
                    <NumericUpDown x:Name="AmbientControl" Minimum="-40" Maximum="60"
                                  Increment="1" FormatString="0"
                                  ValueChanged="OnNumericChanged"/>
                </StackPanel>

                <!-- Time -->
                <TextBlock Text="Time" FontWeight="SemiBold" Margin="0,10,0,0"/>
                <Grid ColumnDefinitions="*,10,*">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Hour (00-23)"/>
                        <NumericUpDown x:Name="HourControl" Minimum="0" Maximum="23"
                                      Increment="1" FormatString="00"
                                      ValueChanged="OnNumericChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Minute (00-59)"/>
                        <NumericUpDown x:Name="MinuteControl" Minimum="0" Maximum="59"
                                      Increment="1" FormatString="00"
                                      ValueChanged="OnNumericChanged"/>
                    </StackPanel>
                </Grid>

                <!-- Indicators -->
                <TextBlock Text="Indicators and Warnings" FontWeight="SemiBold" Margin="0,10,0,0"/>

                <CheckBox x:Name="NeutralCheck" Content="Neutral Gear"
                         IsCheckedChanged="OnCheckChanged"/>
                <CheckBox x:Name="OilCheck" Content="Oil Pressure Warning"
                         IsCheckedChanged="OnCheckChanged"/>
                <CheckBox x:Name="HighBeamCheck" Content="High Beam"
                         IsCheckedChanged="OnCheckChanged"/>
                <CheckBox x:Name="LeftCheck" Content="Left Indicator"
                         IsCheckedChanged="OnCheckChanged"/>
                <CheckBox x:Name="RightCheck" Content="Right Indicator"
                         IsCheckedChanged="OnCheckChanged"/>

                <!-- Settings -->
                <TextBlock Text="Settings" FontWeight="SemiBold" Margin="0,10,0,0"/>

                <StackPanel>
                    <TextBlock Text="Theme (0=White, 1=Green, 2=Red, 3=Blue, 4=Orange, 5=Yellow, 6=Night, 7=High Contrast)"/>
                    <NumericUpDown x:Name="ThemeControl" Minimum="0" Maximum="7"
                                  Increment="1" FormatString="0"
                                  ValueChanged="OnNumericChanged"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Info Mode (0=Standard, 1=Diag, 2=TPMS, 3=Nav)"/>
                    <NumericUpDown x:Name="InfoModeControl" Minimum="0" Maximum="3"
                                  Increment="1" FormatString="0"
                                  ValueChanged="OnNumericChanged"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Units (0=MPH/F/PSI, 1=KMH/C/Bar)"/>
                    <NumericUpDown x:Name="UnitsControl" Minimum="0" Maximum="1"
                                  Increment="1" FormatString="0"
                                  ValueChanged="OnNumericChanged"/>
                </StackPanel>

                <!-- Menu -->
                <TextBlock Text="Menu" FontWeight="SemiBold" Margin="0,10,0,0"/>

                <StackPanel>
                    <TextBlock Text="Menu State (0=Dashboard)"/>
                    <NumericUpDown x:Name="MenuStateControl" Minimum="0" Maximum="999"
                                  Increment="1" FormatString="0"
                                  ValueChanged="OnMenuNumericChanged"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Front Sprocket"/>
                    <NumericUpDown x:Name="FrontSprocketControl" Minimum="10" Maximum="25"
                                  Increment="1" FormatString="0"
                                  ValueChanged="OnMenuNumericChanged"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Rear Sprocket"/>
                    <NumericUpDown x:Name="RearSprocketControl" Minimum="30" Maximum="60"
                                  Increment="1" FormatString="0"
                                  ValueChanged="OnMenuNumericChanged"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Coolant Fan Temp"/>
                    <NumericUpDown x:Name="CoolantFanTempControl" Minimum="60" Maximum="120"
                                  Increment="5" FormatString="0"
                                  ValueChanged="OnMenuNumericChanged"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Day Theme"/>
                    <NumericUpDown x:Name="DayThemeControl" Minimum="0" Maximum="8"
                                  Increment="1" FormatString="0"
                                  ValueChanged="OnMenuNumericChanged"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Night Theme"/>
                    <NumericUpDown x:Name="NightThemeControl" Minimum="0" Maximum="8"
                                  Increment="1" FormatString="0"
                                  ValueChanged="OnMenuNumericChanged"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Fan Neutral Option"/>
                    <NumericUpDown x:Name="FanNeutralOptionControl" Minimum="0" Maximum="3"
                                  Increment="1" FormatString="0"
                                  ValueChanged="OnMenuNumericChanged"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Control Layout"/>
                    <NumericUpDown x:Name="ControlLayoutControl" Minimum="0" Maximum="1"
                                  Increment="1" FormatString="0"
                                  ValueChanged="OnMenuNumericChanged"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Gear Ratio Interval"/>
                    <NumericUpDown x:Name="GearRatioIntervalControl" Minimum="50" Maximum="500"
                                  Increment="50" FormatString="0"
                                  ValueChanged="OnMenuNumericChanged"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Light Switch Value"/>
                    <NumericUpDown x:Name="LightSwitchValueControl" Minimum="0" Maximum="255"
                                  Increment="1" FormatString="0"
                                  ValueChanged="OnMenuNumericChanged"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Current Light Level"/>
                    <NumericUpDown x:Name="CurrentLightLevelControl" Minimum="0" Maximum="255"
                                  Increment="1" FormatString="0"
                                  ValueChanged="OnMenuNumericChanged"/>
                </StackPanel>

                <!-- Navigation -->
                <TextBlock Text="Navigation" FontWeight="SemiBold" Margin="0,10,0,0"/>

                <StackPanel>
                    <TextBlock Text="Symbol"/>
                    <ComboBox x:Name="NavSymbolCombo" SelectedIndex="0" SelectionChanged="OnNavSelectionChanged">
                        <ComboBoxItem Content="(None)"/>
                        <ComboBoxItem Content="MUT — U-turn" Tag="MUT"/>
                        <ComboBoxItem Content="MEX — Motorway exit" Tag="MEX"/>
                        <ComboBoxItem Content="TNR — Turn right" Tag="TNR"/>
                        <ComboBoxItem Content="TNL — Turn left" Tag="TNL"/>
                        <ComboBoxItem Content="SLL — Slight left" Tag="SLL"/>
                        <ComboBoxItem Content="SLR — Slight right" Tag="SLR"/>
                        <ComboBoxItem Content="RB1 — Roundabout 1st exit" Tag="RB1"/>
                        <ComboBoxItem Content="RB2 — Roundabout 2nd exit" Tag="RB2"/>
                        <ComboBoxItem Content="RB3 — Roundabout 3rd exit" Tag="RB3"/>
                        <ComboBoxItem Content="RB4 — Roundabout 4th exit" Tag="RB4"/>
                        <ComboBoxItem Content="RB5 — Roundabout 5th exit" Tag="RB5"/>
                        <ComboBoxItem Content="LNR — Keep right" Tag="LNR"/>
                        <ComboBoxItem Content="LNL — Keep left" Tag="LNL"/>
                        <ComboBoxItem Content="CON — Continue" Tag="CON"/>
                        <ComboBoxItem Content="ARV — Arrive" Tag="ARV"/>
                        <ComboBoxItem Content="PRK — Find parking" Tag="PRK"/>
                        <ComboBoxItem Content="FRY — Take ferry" Tag="FRY"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Road name"/>
                    <TextBox x:Name="NavRoadText" Text="High Street" TextChanged="OnNavTextChanged"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Towards"/>
                    <TextBox x:Name="NavTowardsText" Text="City Centre" TextChanged="OnNavTextChanged"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Exit number (MEX only)"/>
                    <TextBox x:Name="NavExitText" Text="" TextChanged="OnNavTextChanged"/>
                </StackPanel>

                <Grid ColumnDefinitions="*,10,*">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Distance (yards)"/>
                        <NumericUpDown x:Name="NavYardsControl" Minimum="0" Maximum="5000"
                                      Increment="50" FormatString="0" Value="500"
                                      ValueChanged="OnNavNumericChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Distance (miles)"/>
                        <NumericUpDown x:Name="NavMilesControl" Minimum="0" Maximum="500"
                                      Increment="0.1" FormatString="0.0" Value="0.3"
                                      ValueChanged="OnNavNumericChanged"/>
                    </StackPanel>
                </Grid>

                <StackPanel>
                    <TextBlock Text="To destination (miles)"/>
                    <NumericUpDown x:Name="NavDestMilesControl" Minimum="0" Maximum="500"
                                  Increment="0.5" FormatString="0.0" Value="5.0"
                                  ValueChanged="OnNavNumericChanged"/>
                </StackPanel>

                <CheckBox x:Name="NavDrivingLeftCheck" Content="Left-hand drive (UK)"
                         IsChecked="True" IsCheckedChanged="OnNavCheckChanged"/>

                <!-- Preset Buttons -->
                <TextBlock Text="Preset Scenarios (F1-F4)" FontWeight="SemiBold" Margin="0,15,0,0"/>

                <Button Content="F1: Idle" Click="OnIdleClick"
                       HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                <Button Content="F2: Cruising" Click="OnCruiseClick"
                       HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                <Button Content="F3: High Speed Warning" Click="OnWarningClick"
                       HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                <Button Content="F4: Low Fuel" Click="OnLowFuelClick"
                       HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                <Button Content="F5: Navigation" Click="OnNavigationClick"
                       HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>

                <TextBlock Text="Menu Presets (F6-F9)" FontWeight="SemiBold" Margin="0,10,0,0"/>
                <Button Content="F6: Main Menu" Click="OnMainMenuClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                <Button Content="F7: Theme Menu" Click="OnThemeMenuClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                <Button Content="F8: Coolant Fan Menu" Click="OnCoolantFanMenuClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                <Button Content="F9: Sprocket Menu" Click="OnSprocketMenuClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                <Button Content="Set Time Menu" Click="OnSetTimeMenuClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                <Button Content="Set Odo Menu" Click="OnOdometerMenuClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                <Button Content="Units Menu" Click="OnUnitsMenuClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                <Button Content="Speed Correction" Click="OnSpeedCorrectionMenuClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                <Button Content="TPMS Menu" Click="OnTPMSMenuClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                <Button Content="Control Menu" Click="OnControlMenuClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                <Button Content="Light Menu" Click="OnLightMenuClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                <Button Content="Back to Dashboard" Click="OnBackToDashClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>

                <Button Content="Exit (Esc)" Click="OnExitClick"
                       HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                       Margin="0,10,0,0"/>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
