<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:TftDashSimulator.Views"
        xmlns:vm="clr-namespace:TftDashSimulator.ViewModels"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="TftDashSimulator.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        x:CompileBindings="False"
        Title="TFT Dash Simulator"
        Width="1200"
        Height="700">

    <!-- 30/70 Split Layout -->
    <Grid ColumnDefinitions="3*,7*">

        <!-- Left Panel: Controls (30%) -->
        <views:ControlsView Grid.Column="0"
                           DataContext="{Binding}" />

        <!-- Right Panel: Preview (70%) -->
        <views:PreviewView Grid.Column="1"
                          DataContext="{Binding DashboardState}" />

    </Grid>
</Window>
