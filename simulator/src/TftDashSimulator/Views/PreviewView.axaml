<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:core="clr-namespace:TftDashSimulator.Core"
             mc:Ignorable="d" d:DesignWidth="840" d:DesignHeight="700"
             x:Class="TftDashSimulator.Views.PreviewView"
             x:DataType="core:DashboardState">

    <Border Classes="PreviewPanel">
        <DockPanel>

            <!-- Header -->
            <Border DockPanel.Dock="Top"
                   BorderBrush="{DynamicResource BorderBrush}"
                   BorderThickness="0,0,0,1"
                   Padding="10"
                   Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Serial Protocol Preview"
                              FontSize="18"
                              FontWeight="Bold"/>
                    <TextBlock Text="Live Data Message Format: {,speed,rpm,coolant,battery,time,fuel,...,nav,}"
                              FontSize="11"
                              Opacity="0.7"
                              Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Statistics Footer -->
            <Border DockPanel.Dock="Bottom"
                   BorderBrush="{DynamicResource BorderBrush}"
                   BorderThickness="0,1,0,0"
                   Padding="10"
                   Margin="0,10,0,0">
                <StackPanel>
                    <TextBlock x:Name="StatisticsText"
                              FontSize="11"
                              Opacity="0.8"
                              Text="Messages: 0 | Size: 0 bytes | Last updated: --:--:--"/>
                </StackPanel>
            </Border>

            <!-- Message Display (Scrollable) -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                         Padding="10">
                <TextBlock x:Name="MessagePreview"
                          Classes="MonospacePreview"
                          FontSize="12"
                          TextWrapping="Wrap"
                          Text="Waiting for data..."/>
            </ScrollViewer>

        </DockPanel>
    </Border>

</UserControl>
