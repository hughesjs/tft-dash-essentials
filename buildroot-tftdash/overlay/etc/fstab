# /etc/fstab — TFT Dash (A/B rootfs scheme)
# Root filesystem is mounted by the kernel via cmdline.txt root= parameter.
# Do not add a / entry here — the active slot (p2 or p3) is determined at boot.
/dev/mmcblk0p1  /boot   vfat    defaults,ro     0       0
/dev/mmcblk0p4  /data   ext4    defaults,noatime,rw     0       0
sysfs           /sys    sysfs   defaults        0       0
tmpfs           /tmp    tmpfs   nosuid,nodev    0       0
tmpfs           /var/log tmpfs  nosuid,nodev    0       0
tmpfs           /var/tmp tmpfs  nosuid,nodev    0       0
